#!/usr/bin/env python3
"""Process image for TRMNL e-ink display.
Resizes to 800x480 with aspect-preserving fill/crop,
converts to 1-bit black/white using Floyd-Steinberg dithering.
Output: same path with '-full' removed from filename.
"""
import os
import sys
from pathlib import Path

try:
    from PIL import Image
except ImportError:
    Image = None


def main():
    if len(sys.argv) < 2:
        print("Usage: process-image <input-full.png-or.jpg>", file=sys.stderr)
        sys.exit(1)

    input_path = Path(sys.argv[1])
    if not input_path.exists():
        print(f"Error: Input file not found: {input_path}", file=sys.stderr)
        sys.exit(1)

    # Handle JPEG-in-PNG disguise (Gemini quirk)
    raw = input_path.read_bytes()
    is_jpeg = raw[:2] == b'\xff\xd8'

    # Generate output filename (remove -full suffix)
    out_name = input_path.name.replace("-full", "")
    if out_name == input_path.name:
        out_name = input_path.stem + "-processed" + input_path.suffix
    out_path = input_path.parent / out_name

    print(f"Processing image for TRMNL...", file=sys.stderr)
    print(f"  Input:  {input_path}", file=sys.stderr)
    print(f"  Output: {out_path}", file=sys.stderr)
    if is_jpeg:
        print(f"  Note:   input is JPEG-in-PNG (Gemini quirk)", file=sys.stderr)

    # Use Python Pillow if available
    if Image is not None:
        img = Image.open(input_path)
        src_dims = f"{img.width}x{img.height}"
    else:
        print("Error: Pillow not installed. Install with: pip install Pillow", file=sys.stderr)
        sys.exit(1)

    print(f"  Source: {src_dims}", file=sys.stderr)

    # Aspect-preserving fill/crop to 800x480
    target_w, target_h = 800, 480
    img_ratio = img.width / img.height
    target_ratio = target_w / target_h

    if img_ratio > target_ratio:
        # Wider than target: crop sides
        new_w = int(img.height * target_ratio)
        offset = (img.width - new_w) // 2
        img = img.crop((offset, 0, offset + new_w, img.height))
    else:
        # Taller than target: crop top/bottom
        new_h = int(img.width / target_ratio)
        offset = (img.height - new_h) // 2
        img = img.crop((0, offset, img.width, offset + new_h))

    img = img.resize((target_w, target_h), Image.LANCZOS)

    # Convert to grayscale
    img = img.convert('L')

    # Gemini tends to generate mid-dark images. Lighten slightly before
    # dithering so the e-ink version stays airy and readable.
    img = img.point(lambda x: min(255, int(x * 2.0)))

    # Floyd-Steinberg dither to 1-bit
    img_dithered = img.convert('1', dither=Image.FLOYDSTEINBERG)
    out_path = out_path.with_suffix(".png")
    img_dithered.save(out_path, optimize=True)
    size_kb = os.path.getsize(out_path) // 1024
    print(f"  Floyd-Steinberg dither: {size_kb}KB", file=sys.stderr)

    if size_kb > 90:
        print(f"  {size_kb}KB exceeds 90KB limit — downsizing to 640x384...", file=sys.stderr)
        # Downsize to reduce pixel count, re-process
        img_small = img.resize((640, 384), Image.LANCZOS)
        img_small = img_small.convert('1', dither=Image.FLOYDSTEINBERG)
        img_small.save(out_path, optimize=True)
        size_kb = os.path.getsize(out_path) // 1024
        print(f"  Downsized dither: {size_kb}KB (640x384)", file=sys.stderr)

    # Copy to latest.png
    repo_root = Path(__file__).resolve().parent.parent
    latest = repo_root / "output" / "latest.png"
    latest.unlink(missing_ok=True)
    import shutil
    shutil.copy2(out_path, latest)
    print(f"  Latest: {latest}", file=sys.stderr)

    print(out_path)


if __name__ == "__main__":
    main()
