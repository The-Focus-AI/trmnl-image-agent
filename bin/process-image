#!/usr/bin/env python3
"""Process image for TRMNL e-ink display.
Resizes to 800x480 with aspect-preserving fill/crop.
Converts to 1-bit using clean thresholding with auto level.
"""
import sys
from pathlib import Path

try:
    from PIL import Image
except ImportError:
    Image = None


def auto_level(img):
    """Stretch histogram to use full range before thresholding."""
    pixels = list(img.getdata())
    lo = min(pixels)
    hi = max(pixels)
    if hi - lo < 10:
        return img
    return img.point(lambda x: int((x - lo) * 255 / (hi - lo)))


def main():
    if len(sys.argv) < 2:
        print("Usage: process-image <input-full.png-or-jpg>", file=sys.stderr)
        sys.exit(1)

    input_path = Path(sys.argv[1])
    if not input_path.exists():
        print(f"Error: Input file not found: {input_path}", file=sys.stderr)
        sys.exit(1)

    raw = input_path.read_bytes()
    is_jpeg = raw[:2] == b'\xff\xd8'

    out_name = input_path.name.replace("-full", "")
    if out_name == input_path.name:
        out_name = input_path.stem + "-processed" + input_path.suffix
    out_path = input_path.parent / out_name
    out_path = out_path.with_suffix(".png")

    print(f"Processing image for TRMNL...", file=sys.stderr)
    print(f"  Input:  {input_path}", file=sys.stderr)
    print(f"  Output: {out_path}", file=sys.stderr)

    if Image is None:
        print("Error: Pillow not installed.", file=sys.stderr)
        sys.exit(1)

    img = Image.open(input_path)
    print(f"  Source: {img.width}x{img.height}", file=sys.stderr)

    # Aspect-preserving fill/crop to 800x480
    target_w, target_h = 800, 480
    img_ratio = img.width / img.height
    target_ratio = target_w / target_h

    if img_ratio > target_ratio:
        new_w = int(img.height * target_ratio)
        offset = (img.width - new_w) // 2
        img = img.crop((offset, 0, offset + new_w, img.height))
    else:
        new_h = int(img.width / target_ratio)
        offset = (img.height - new_h) // 2
        img = img.crop((0, offset, img.width, offset + new_h))

    img = img.resize((target_w, target_h), Image.LANCZOS)
    img = img.convert('L')

    # Straight threshold at 40% (102/255) — only pixels darker than
    # 40% gray become black, keeping the image light and airy.
    # No auto_level — that stretches midtones and makes things worse.
    img = img.point(lambda x: 255 if x > 51 else 0, '1')

    img.save(out_path, optimize=True)
    size_kb = out_path.stat().st_size // 1024

    # If over 90KB, bump threshold to 60%
    if size_kb > 90:
        print(f"  {size_kb}KB — retrying with 60% threshold", file=sys.stderr)
        img2 = Image.open(input_path)
        if img_ratio > target_ratio:
            new_w = int(img2.height * target_ratio)
            offset = (img2.width - new_w) // 2
            img2 = img2.crop((offset, 0, offset + new_w, img2.height))
        else:
            new_h = int(img2.width / target_ratio)
            offset = (img2.height - new_h) // 2
            img2 = img2.crop((0, offset, img2.width, offset + new_h))
        img2 = img2.resize((target_w, target_h), Image.LANCZOS)
        img2 = img2.convert('L')
        img2 = auto_level(img2)
        img2 = img2.point(lambda x: 255 if x > 153 else 0, '1')
        img2.save(out_path, optimize=True)
        size_kb = out_path.stat().st_size // 1024

    print(f"  Size:   {size_kb}KB", file=sys.stderr)

    # Copy to latest.png
    repo_root = Path(__file__).resolve().parent.parent
    latest = repo_root / "output" / "latest.png"
    latest.unlink(missing_ok=True)
    import shutil
    shutil.copy2(out_path, latest)
    print(f"  Latest: {latest}", file=sys.stderr)

    print(out_path)


if __name__ == "__main__":
    main()
