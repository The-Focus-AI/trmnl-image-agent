#!/bin/bash
# Build TRMNL image prompt from parsed JSON data via Python state engine
# Reads from /tmp/trmnl-data/parsed.json
# Outputs prompt to /tmp/trmnl-prompt.txt

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
INPUT_FILE="/tmp/trmnl-data/parsed.json"
OUTPUT_FILE="/tmp/trmnl-prompt.txt"
PLANTING_FILE="$PROJECT_DIR/prompts/planting-calendar-zone6a.json"
POLLEN_FILE="$PROJECT_DIR/prompts/pollen-calendar-zone6a.json"
SCHOOL_FILE="$PROJECT_DIR/prompts/school-calendar.json"

if [ ! -f "$INPUT_FILE" ]; then
  echo "Error: Missing $INPUT_FILE - run parse-data first" >&2
  exit 1
fi

python3 "$PROJECT_DIR/trmnl_prompt_builder.py" \
  --input "$INPUT_FILE" \
  --output "$OUTPUT_FILE" \
  --planting "$PLANTING_FILE" \
  --pollen "$POLLEN_FILE" \
  --school "$SCHOOL_FILE" > /tmp/trmnl-build-prompt.out

cat "$OUTPUT_FILE" >&2
printf '\n' >&2
cat /tmp/trmnl-build-prompt.out
