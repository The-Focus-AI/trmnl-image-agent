#!/bin/bash
# Generate TRMNL image using local Gemini image wrapper
# Uses prompt from /tmp/trmnl-prompt.txt
# Outputs to output/YYYY-MM/YYYY-MM-DD-HH-MM-full.png

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROMPT_FILE="${1:-/tmp/trmnl-prompt.txt}"
OUTPUT_DIR="output/$(date +%Y-%m)"
OUTPUT_FILE="$OUTPUT_DIR/$(date +%Y-%m-%d-%H-%M)-full.png"
ENV_FILE="$PROJECT_DIR/.env"
IMAGE_MODEL="${TRMNL_IMAGE_MODEL:-gemini-3.1-flash-image-preview}"
IMAGE_SIZE="${TRMNL_IMAGE_SIZE:-1K}"
IMAGE_ASPECT="${TRMNL_IMAGE_ASPECT:-}"
IMAGE_MIME_TYPE="${TRMNL_IMAGE_MIME_TYPE:-image/png}"

if [ ! -f "$PROMPT_FILE" ]; then
  echo "Error: Prompt file not found: $PROMPT_FILE" >&2
  echo "Run build-prompt first" >&2
  exit 1
fi

# Ensure output directory exists
mkdir -p "$OUTPUT_DIR"

# Load .env if available before falling back to 1Password
if [ -z "${GEMINI_API_KEY:-}" ] && [ -f "$ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

# Check for GEMINI_API_KEY
if [ -z "${GEMINI_API_KEY:-}" ]; then
  if command -v op >/dev/null 2>&1; then
    export GEMINI_API_KEY="$(op read 'op://Development/Google AI Studio Key/notesPlain')"
  else
    echo "Error: GEMINI_API_KEY not set and 1Password CLI not available" >&2
    exit 1
  fi
fi

if [ ! -d "$PROJECT_DIR/node_modules" ]; then
  echo "Installing local Node dependencies for Gemini image wrapper..." >&2
  npm install --no-fund --no-audit >&2
fi

CMD=(node "$PROJECT_DIR/scripts/gemini-image-cli.mjs" \
  --prompt-file "$PROMPT_FILE" \
  --output "$OUTPUT_FILE" \
  --model "$IMAGE_MODEL" \
  --image-size "$IMAGE_SIZE" \
  --mime-type "$IMAGE_MIME_TYPE")

if [ -n "$IMAGE_ASPECT" ]; then
  CMD+=(--aspect "$IMAGE_ASPECT")
fi

# Fix: Gemini may write JPEG data to the .png file
# After generation, check the header and rename if needed
echo "Generating image with local Gemini wrapper..." >&2
"${CMD[@]}"

# Check actual format and rename if needed
REAL_TYPE=$(file "$OUTPUT_FILE" | grep -o 'JPEG\|PNG' | head -1)
if [ "$REAL_TYPE" = "JPEG" ]; then
  JPEG_FILE="${OUTPUT_FILE%.png}.jpg"
  mv "$OUTPUT_FILE" "$JPEG_FILE"
  echo "  Note: Gemini output was JPEG, renamed to .jpg" >&2
  echo "$JPEG_FILE"
else
  echo "$OUTPUT_FILE"
fi
