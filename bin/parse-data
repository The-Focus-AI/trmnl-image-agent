#!/bin/bash
# Parse raw weather and Mohawk data using Claude Haiku
# Reads from /tmp/trmnl-data/
# Outputs JSON to /tmp/trmnl-data/parsed.json

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DATA_DIR="/tmp/trmnl-data"
OUTPUT_FILE="$DATA_DIR/parsed.json"

# Check for required files
if [ ! -f "$DATA_DIR/weather.html" ]; then
  echo "Error: Missing $DATA_DIR/weather.html" >&2
  exit 1
fi

if [ ! -f "$DATA_DIR/mohawk.txt" ]; then
  echo "Error: Missing $DATA_DIR/mohawk.txt" >&2
  exit 1
fi


# Create the prompt for Haiku using build-prompt-data.py
PROMPT=$("$SCRIPT_DIR/build-prompt-data.py")
echo "Parsing data with Claude Haiku..." >&2

# Call Claude with haiku model and text output format
# Unset CLAUDECODE to allow running from within a Claude Code session
RESULT=$(echo "$PROMPT" | CLAUDECODE= claude --model haiku --print --permission-mode bypassPermissions 2>/dev/null)

# Extract JSON from the result - handle markdown code blocks
CLEAN_RESULT=$(echo "$RESULT" | sed 's/^```json//' | sed 's/^```//' | sed 's/```$//')

# Find the JSON object
JSON_RESULT=$(echo "$CLEAN_RESULT" | grep -o '{[^}]*"date"[^}]*}' | head -1)

# If that didn't work, try to extract everything between first { and last }
if [ -z "$JSON_RESULT" ] || ! echo "$JSON_RESULT" | jq . > /dev/null 2>&1; then
  # More aggressive extraction - get content between first { and matching }
  JSON_RESULT=$(echo "$CLEAN_RESULT" | awk '/{/{p=1} p{print} /}/{p=0}' | tr '\n' ' ')
fi

# Write to output file
echo "$JSON_RESULT" > "$OUTPUT_FILE"

# Validate JSON
if jq . "$OUTPUT_FILE" > /dev/null 2>&1; then
  echo "Parsed data written to $OUTPUT_FILE" >&2
else
  echo "Warning: JSON validation failed, attempting to fix..." >&2
  # Try to extract just the JSON part more aggressively
  echo "$CLEAN_RESULT" | python3 -c "
import sys
import json
import re

text = sys.stdin.read()
# Find JSON-like content
match = re.search(r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}', text, re.DOTALL)
if match:
    try:
        obj = json.loads(match.group())
        print(json.dumps(obj, indent=2))
    except:
        print(text)
else:
    print(text)
" > "$OUTPUT_FILE" 2>/dev/null || echo "$CLEAN_RESULT" > "$OUTPUT_FILE"
fi

# Override maple fields deterministically (LLM gets these wrong)
# Sap flows when it freezes at night and thaws during the day
HIGH=$(jq -r '.weather.high // 32' "$OUTPUT_FILE")
LOW=$(jq -r '.weather.low // 32' "$OUTPUT_FILE")

if [ "$HIGH" -gt 32 ] 2>/dev/null && [ "$LOW" -lt 32 ] 2>/dev/null; then
  SAP_FLOWING=true
else
  SAP_FLOWING=false
fi

if [ "$SAP_FLOWING" = "true" ] && [ "$HIGH" -ge 40 ] 2>/dev/null && [ "$HIGH" -le 50 ] 2>/dev/null && [ "$LOW" -ge 20 ] 2>/dev/null && [ "$LOW" -le 28 ] 2>/dev/null; then
  MAPLE_QUALITY="ideal"
elif [ "$SAP_FLOWING" = "true" ] && [ "$HIGH" -ge 33 ] 2>/dev/null && [ "$HIGH" -le 55 ] 2>/dev/null; then
  MAPLE_QUALITY="good"
else
  MAPLE_QUALITY="poor"
fi

# Patch maple fields in JSON
jq --argjson sap "$SAP_FLOWING" --arg quality "$MAPLE_QUALITY" \
  '.maple.sap_flowing = $sap | .maple.quality = $quality' "$OUTPUT_FILE" > "${OUTPUT_FILE}.tmp" \
  && mv "${OUTPUT_FILE}.tmp" "$OUTPUT_FILE"

# Fix banner: only show sap_flowing banner if sap is actually flowing
MOHAWK_STATUS=$(jq -r '.mohawk.status // "open"' "$OUTPUT_FILE")
BANNER_TYPE=$(jq -r '.banner.type // "normal"' "$OUTPUT_FILE")

if [ "$SAP_FLOWING" = "false" ] && [ "$BANNER_TYPE" = "sap_flowing" ]; then
  # Sap isn't flowing, clear the sap banner
  jq '.banner.type = "normal" | .banner.text = null' "$OUTPUT_FILE" > "${OUTPUT_FILE}.tmp" \
    && mv "${OUTPUT_FILE}.tmp" "$OUTPUT_FILE"
elif [ "$SAP_FLOWING" = "true" ] && [ "$MOHAWK_STATUS" = "closed" ] && [ "$BANNER_TYPE" != "sap_flowing" ]; then
  # Sap is flowing and mountain closed, set the sap banner
  BANNER="🍁 SAP IS FLOWING • HIGH ${HIGH}° LOW ${LOW}° 🍁"
  jq --arg text "$BANNER" '.banner.type = "sap_flowing" | .banner.text = $text' "$OUTPUT_FILE" > "${OUTPUT_FILE}.tmp" \
    && mv "${OUTPUT_FILE}.tmp" "$OUTPUT_FILE"
fi

echo "Maple override: sap_flowing=$SAP_FLOWING quality=$MAPLE_QUALITY (high=$HIGH low=$LOW)" >&2

# Determine if Mohawk is closed for the season (off-season placeholder text)
MOHAWK_TEXT=$(jq -r '.mohawk.status // "open"' "$OUTPUT_FILE")
if grep -q "closed for the season" "$DATA_DIR/mohawk.txt" 2>/dev/null; then
  jq '.mohawk.status = "closed_season"' "$OUTPUT_FILE" > "${OUTPUT_FILE}.tmp" \
    && mv "${OUTPUT_FILE}.tmp" "$OUTPUT_FILE"
fi

# Add season_indicators: frost_risk and growing_conditions
# Frost risk: if tonight's low <= 32°F during growing season (Apr-Oct)
CURRENT_MONTH=$(TZ='America/New_York' date "+%-m")
FROST_RISK="none"
if [ "$CURRENT_MONTH" -ge 3 ] && [ "$CURRENT_MONTH" -le 5 ]; then
  if [ "$LOW" -le 28 ] 2>/dev/null; then
    FROST_RISK="hard_freeze"
  elif [ "$LOW" -le 32 ] 2>/dev/null; then
    FROST_RISK="frost"
  elif [ "$LOW" -le 36 ] 2>/dev/null; then
    FROST_RISK="light_frost"
  fi
elif [ "$CURRENT_MONTH" -ge 9 ] && [ "$CURRENT_MONTH" -le 10 ]; then
  if [ "$LOW" -le 28 ] 2>/dev/null; then
    FROST_RISK="hard_freeze"
  elif [ "$LOW" -le 32 ] 2>/dev/null; then
    FROST_RISK="frost"
  elif [ "$LOW" -le 36 ] 2>/dev/null; then
    FROST_RISK="light_frost"
  fi
fi

# Growing conditions based on temperature range
GROWING_CONDITIONS="dormant"
if [ "$HIGH" -ge 60 ] 2>/dev/null && [ "$LOW" -ge 40 ] 2>/dev/null; then
  GROWING_CONDITIONS="ideal"
elif [ "$HIGH" -ge 50 ] 2>/dev/null && [ "$LOW" -ge 32 ] 2>/dev/null; then
  GROWING_CONDITIONS="good"
elif [ "$HIGH" -ge 40 ] 2>/dev/null; then
  GROWING_CONDITIONS="cool"
fi

# Patch season_indicators into JSON
jq --arg frost "$FROST_RISK" --arg growing "$GROWING_CONDITIONS" \
  '.season_indicators = {"frost_risk": $frost, "growing_conditions": $growing}' \
  "$OUTPUT_FILE" > "${OUTPUT_FILE}.tmp" \
  && mv "${OUTPUT_FILE}.tmp" "$OUTPUT_FILE"

echo "Season indicators: frost_risk=$FROST_RISK growing=$GROWING_CONDITIONS" >&2

echo "$OUTPUT_FILE"
