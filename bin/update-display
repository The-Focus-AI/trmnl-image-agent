#!/bin/bash
# Main script to update TRMNL display
# Runs all steps: fetch → parse → prompt → generate → process
# Then commit/push to deploy via GitHub Pages

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
START_TIME=$(date +%s)

echo "==========================================" >&2
echo "TRMNL Display Update - $(date)" >&2
echo "==========================================" >&2
echo "" >&2

# Step 1: Fetch all raw data in parallel
echo "Step 1/5: Fetching raw data (parallel)..." >&2
"$SCRIPT_DIR/fetch-all"
FETCH_TIME=$(date +%s)
echo "  Done in $((FETCH_TIME - START_TIME))s" >&2
echo "" >&2

# Step 2: Parse data with Haiku
echo "Step 2/5: Parsing data with AI..." >&2
"$SCRIPT_DIR/parse-data" > /dev/null
PARSE_TIME=$(date +%s)
echo "  Done in $((PARSE_TIME - FETCH_TIME))s" >&2
echo "" >&2

# Step 3: Build prompt from parsed data
echo "Step 3/5: Building image prompt..." >&2
"$SCRIPT_DIR/build-prompt" > /dev/null
PROMPT_FILE="/tmp/trmnl-prompt.txt"
BUILD_TIME=$(date +%s)
echo "  Prompt: $PROMPT_FILE" >&2
echo "  Done in $((BUILD_TIME - PARSE_TIME))s" >&2
echo "" >&2

# Step 4: Generate image with AI
echo "Step 4/5: Generating image..." >&2
FULL_IMAGE=$("$SCRIPT_DIR/generate-image" "$PROMPT_FILE" | tail -1)
GEN_TIME=$(date +%s)
echo "  Output: $FULL_IMAGE" >&2
echo "  Done in $((GEN_TIME - BUILD_TIME))s" >&2
echo "" >&2

# Step 5: Process image for TRMNL (also copies to latest.png)
echo "Step 5/5: Processing image for e-ink..." >&2
FINAL_IMAGE=$("$SCRIPT_DIR/process-image" "$FULL_IMAGE" | tail -1)
PROC_TIME=$(date +%s)
echo "  Output: $FINAL_IMAGE" >&2
echo "  Done in $((PROC_TIME - GEN_TIME))s" >&2
echo "" >&2

# Summary
TOTAL_TIME=$((PROC_TIME - START_TIME))
echo "==========================================" >&2
echo "Complete! Total time: ${TOTAL_TIME}s" >&2
echo "" >&2
echo "Timing breakdown:" >&2
echo "  Fetch:    $((FETCH_TIME - START_TIME))s" >&2
echo "  Parse:    $((PARSE_TIME - FETCH_TIME))s" >&2
echo "  Prompt:   $((BUILD_TIME - PARSE_TIME))s" >&2
echo "  Generate: $((GEN_TIME - BUILD_TIME))s" >&2
echo "  Process:  $((PROC_TIME - GEN_TIME))s" >&2
echo "" >&2
echo "Final image: $FINAL_IMAGE" >&2
echo "Latest:      output/latest.png" >&2
echo "" >&2
echo "Commit and push to deploy via GitHub Pages" >&2
echo "==========================================" >&2

# Output the final image path for scripting (only stdout line)
echo "$FINAL_IMAGE"
